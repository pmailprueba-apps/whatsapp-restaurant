# WhatsApp Provider: "webjs" (default) | "direct" | "simulator"
WHATSAPP_PROVIDER=webjs

# whatsapp-web.js (modo webjs - escanea QR con tu teléfono)
# No necesita credenciales de Meta API
WEBJS_PORT=3001

# Meta WhatsApp Cloud API (modo direct - SOLO si usas WHATSAPP_PROVIDER=direct)
WHATSAPP_TOKEN=tu_access_token_de_meta
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id

# General
WHATSAPP_VERIFY_TOKEN=mi_verify_token_123
OWNER_PHONE=5215512345678

# ManyChat (descomenta y configura si usas ManyChat)
# MANYCHAT_API_KEY=MC_tu_api_key
# MANYCHAT_VERIFY_TOKEN=restaurant123